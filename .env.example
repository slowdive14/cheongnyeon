# 청년정책 진단 — 환경 변수 템플릿
# 사용법: 이 파일을 `.env` 로 복사한 뒤 값을 채우세요. `.env` 는 git에 커밋되지 않습니다.
# 키가 없어도 앱·테스트는 fixture/mock 모드로 완전히 동작합니다. (키는 실데이터 적재 시에만 필요)

# 온통청년 / 청년정책 Open API 인증키 (공공데이터포털 data.go.kr 에서 발급)
# 미설정 시 ontongClient 는 test/fixtures 의 샘플 데이터로 동작합니다.
ONTONG_API_KEY=

# Gemini API 키 (Google AI Studio aistudio.google.com 에서 발급)
# 미설정 시 LLM 파싱/해석/설명은 비활성(버튼 흐름·키워드 폴백)으로 동작합니다.
GEMINI_API_KEY=
